{
  "manifest_version": 3,
  "name": "Figma Bridge",
  "version": "2.7.0",
  "description": "Figma Bridge — auto-injects helper functions for Claude Code's Figma automation",
  "permissions": [
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "https://www.figma.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}